{{> header}}
  <mj-section padding="0">
    <mj-column>

      <!-- Title -->
      <mj-text font-size="28px" font-weight="400" color="#000000" padding-bottom="16px">
        Welcome to Leiaqa
      </mj-text>

      <!-- Greeting -->
      <mj-text font-size="16px" color="#000000" padding-bottom="8px">
        Dear {{data.lecturerName}},
      </mj-text>

      <!-- Paragraph 1 -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        Congratulations and welcome to the Leiaqa community!
      </mj-text>

      <!-- Paragraph 2 -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        We’re thrilled to let you know that your instructor account request has been approved. You’re now part of our vibrant community of educators who are passionate about sharing knowledge and creating impactful learning experiences.
      </mj-text>

      <!-- Paragraph 3 -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        You can access the instructor board to start uploading your courses and managing your content.
      </mj-text>

      <!-- Paragraph 4 -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        To get started, click the button below:
      </mj-text>

      <!-- CTA Button -->
      <mj-button align="left" border-radius="6px" background-color="#76003E" color="#ffffff" font-size="16px" padding-bottom="20px" href="{{data.url}}">
        Go to my board
      </mj-button>

      <!-- Support Message -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        If you have any questions or need assistance, feel free to reach out to our support team at 
        <a href="mailto:info@leiaq.com" style="color:#660043; text-decoration:underline;">info@leiaq.com</a>.
      </mj-text>

      <!-- Closing -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        We’re excited to see the incredible programs you’ll create and the impact you’ll make on learners worldwide. Welcome aboard!
      </mj-text>
{{> footer}}