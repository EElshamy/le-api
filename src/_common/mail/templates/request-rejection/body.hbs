{{> header}}
<mj-section padding="0">
  <mj-column>

    <!-- Title -->
    <mj-text font-size="28px" font-weight="400" color="#000000" padding-bottom="16px">
      Important update on your instructor application
    </mj-text>

    <!-- Greeting -->
    <mj-text font-size="16px" color="#000000" padding-bottom="8px">
      Dear {{data.lecturerName}},
    </mj-text>

    <!-- Paragraph 1 -->
    <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
      Thank you for your interest in joining the Leiaqa community as an instructor. After careful review of your application, we regret to inform you that your request has not been approved at this time.
    </mj-text>

    <!-- Rejection Reason -->
    <mj-section background-color="#EDEAE7" padding="10px"  border-radius="6px">
      <mj-column>
        <mj-text font-size="16px" color="#000000" line-height="1.6">
          <strong>This decision was based on the following reason(s):</strong><br/>
          {{data.rejectionReason}}
        </mj-text>
      </mj-column>
  </mj-section>
    <!-- Paragraph 2 -->
    <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
      We encourage you to review the requirements and submit a new application if you feel you can address the outlined concerns.
    </mj-text>

    <!-- Support Message -->
    <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
      If you have any questions about your application or need further guidance, please don’t hesitate to contact our support team at 
      <a href="mailto:info@leiaq.com" style="color:#660043; text-decoration:underline;">info@leiaq.com</a>. We’re here to help and would be happy to assist you.
    </mj-text>

    <!-- Closing -->
    <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
      Thank you again for your interest in Leiaqa. We hope to see you reapply in the future.
    </mj-text>


{{> footer}}