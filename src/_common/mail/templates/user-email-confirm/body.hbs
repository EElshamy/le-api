{{> header}}

              <!-- Title -->
              <mj-text font-size="28px" font-weight="400" color="#000000" padding-bottom="8px">
                Welcome to Leiaqa!
              </mj-text>

              <!-- Message -->
              <mj-text>
                Welcome to Leiaqa! We're thrilled to have you as part of our community of passionate educators.
                <br /><br />
                Please enter the following One-Time Password (OTP) in the application:
              </mj-text>

              <!-- OTP -->
              <mj-text font-size="48px" font-weight="bold" color="#780043" align="center" padding="24px 0">
                {{data.otp}}
              </mj-text>

              <!-- Expiry -->
              <mj-text>
                This code will expire after <strong>10 minutes</strong>.
              </mj-text>

              <!-- If not you -->
              <mj-text>
                If you did not register for Leiaqa or did not request this OTP, you can safely ignore this email.
              </mj-text>

              <!-- Thank you -->
              <mj-text>
                Thank you for partnering with Leiaqa. Together, we’re creating impactful learning experiences for students worldwide!
              </mj-text>

{{> footer}}
