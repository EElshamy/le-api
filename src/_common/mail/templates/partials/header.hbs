<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all font-family="Arial, Helvetica, sans-serif" color="#333333" />
      <mj-text font-size="16px" line-height="1.6" />
    </mj-attributes>
    <mj-style>
      a { color: #333333; text-decoration: underline; }
    </mj-style>

    <!-- Responsive Styles -->
    <mj-style inline="inline">
      @media only screen and (max-width:480px) {
      .title-text {
      font-size: 26px !important;
      line-height: 34px !important;
      padding: 0 10px 12px 10px !important;
      }
      .desc-text {
      font-size: 14px !important;
      line-height: 22px !important;
      padding: 10px !important;
      }
      }
    </mj-style>
  </mj-head>

  <mj-body background-color="#E7E7E7">
    <!-- Outer Container -->
    <mj-section padding="24px 0">
      <mj-column width="100%" padding="0">
        <!-- Card -->
        <mj-section background-color="#F8F5F3" border-radius="10px" padding="32px 24px" width="680px" align="center">
          <mj-column width="100%">
            <!-- Logo -->
            <mj-image src="https://leiaqa-production.fra1.digitaloceanspaces.com/assets/emails/en-logo.png" width="140px" align="left" padding-bottom="16px" alt="Leiaqa Logo" />
