{{> header}}
<mj-section padding="0px">
  <mj-column width="100%">
    <!-- Title -->
    <mj-text align="left" color="#33082f" font-size="30px" font-family="Somar Sans Medium" font-weight="bold" padding-bottom="15px" css-class="title-text">
      {{data.title}}
    </mj-text>

    <!-- Description -->
    <mj-text align="left" color="#555555" font-size="16px" line-height="28px" padding="15px 25px" css-class="desc-text">
      {{data.description}}
    </mj-text>
  </mj-column>
</mj-section>
{{> footer}}