{{> header}}
  <mj-section padding="0">
    <mj-column>

      <!-- Title -->
      <mj-text font-size="28px" font-weight="400" color="#000000" padding-bottom="16px">
        Special discount on your selected program!
      </mj-text>

      <!-- Paragraph 1 -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        We noticed that you’ve added <strong>{{data.programTitle}}</strong> to your cart but haven’t completed the purchase yet.
      </mj-text>

      <!-- Paragraph 2 -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        To help you take the next step in your learning journey, we’re offering you an exclusive discount on this program!
      </mj-text>

      <!-- Paragraph 3 -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        Don’t miss this opportunity to enroll at a reduced price. Complete your purchase now and start learning today!
      </mj-text>

      <!-- Paragraph 4 -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        Click the button below to claim your discount:
      </mj-text>

      <!-- CTA Button -->
      <mj-button align="left" border-radius="6px" background-color="#76003E" color="#ffffff" font-size="16px" padding-bottom="20px" href="{{data.url}}">
        Complete your purchase
      </mj-button>

      <!-- Support Message -->
      <mj-text font-size="16px" color="#000000" padding-bottom="12px" line-height="1.6">
        If you have any questions or need assistance, feel free to reach out to our support team at
        <a href="mailto:info@leiaq.com" style="color:#660043; text-decoration:underline;">info@leiaq.com</a>.
      </mj-text>

{{> footer}}